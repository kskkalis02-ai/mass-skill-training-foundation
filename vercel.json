{
  "version": 2,
  "routes": [
    {
      "src": "/sitemap.xml",
      "headers": {
        "Content-Type": "application/xml; charset=utf-8",
        "Cache-Control": "public, max-age=3600"
      },
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "headers": {
        "Content-Type": "text/plain; charset=utf-8"
      },
      "dest": "/robots.txt"
    },
    {
      "src": "/(.*)\\.html",
      "headers": {
        "Content-Type": "text/html; charset=utf-8"
      },
      "dest": "/$1.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}